{
  "name": "altidigitech-video-templates",
  "private": true,
  "packageManager": "bun@1.2.9",
  "workspaces": [
    "packages/*",
    "projects/*"
  ],
  "scripts": {
    "dev": "bun dev:store-md",
    "dev:leak-detector": "remotion studio --props='{\"saas\":\"leak-detector\"}' projects/leak-detector/src/index.ts",
    "dev:store-md": "remotion studio --props='{\"saas\":\"store-md\"}' projects/store-md/src/index.ts",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "render": "bun scripts/render-formats.ts",
    "render:leak-detector": "bun scripts/render-formats.ts --saas=leak-detector",
    "render:all": "bun scripts/render-all.ts",
    "new:saas": "bun scripts/new-saas.ts",
    "screenshots:leak-detector": "bun scripts/capture-screenshots.ts --url=https://leakdetector.tech",
    "screenshots:leak-detector:local": "bun scripts/capture-screenshots.ts --url=http://localhost:3000",
    "playwright:install": "bunx playwright install chromium"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "playwright": "^1.43.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@remotion/cli": "4.0.434",
    "@remotion/google-fonts": "4.0.434",
    "@remotion/media-utils": "4.0.434",
    "@remotion/motion-blur": "4.0.434",
    "@remotion/noise": "4.0.434",
    "@remotion/paths": "4.0.434",
    "@remotion/player": "4.0.434",
    "@remotion/renderer": "4.0.434",
    "@remotion/sfx": "4.0.434",
    "@remotion/shapes": "4.0.434",
    "@remotion/transitions": "4.0.434",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.434",
    "zod": "4.3.6"
  }
}
